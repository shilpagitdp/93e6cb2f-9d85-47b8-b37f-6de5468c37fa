# Dockerfile for running tests
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS test
WORKDIR /src

# Copy solution files
COPY ["LongestSequenceSolution.csproj", "./LongestSequenceSolution/"]
COPY ["../TestProject1/LongestSequenceSolutionTests.csproj", "./TestProject1/"]

WORKDIR /src/TestProject1
RUN dotnet restore "LongestSequenceSolutionTests.csproj"

WORKDIR /src
COPY . ./LongestSequenceSolution/
COPY ../TestProject1/ ./TestProject1/

# Run tests
WORKDIR /src/TestProject1
RUN dotnet test --logger "console;verbosity=detailed" --no-restore

# If tests pass, build the app
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src
COPY ["LongestSequenceSolution.csproj", "./"]
RUN dotnet restore
COPY . .
RUN dotnet build -c Release -o /app/build

FROM build AS publish
RUN dotnet publish -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/runtime:8.0 AS final
WORKDIR /app
COPY --from=publish /app/publish .
ENTRYPOINT ["dotnet", "LongestSequenceSolution.dll"]
